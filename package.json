{
  "name": "token2022-guard",
  "version": "0.2.3",
  "description": "Pre-mainnet safety checks for Solana Token-2022 integrations. CLI, VS Code, SARIF.",
  "license": "MIT",
  "author": "panagot",
  "repository": {
    "type": "git",
    "url": "https://github.com/panagot/token2022-guard.git"
  },
  "homepage": "https://token2022-guard.vercel.app",
  "bugs": {
    "url": "https://github.com/panagot/token2022-guard/issues"
  },
  "keywords": [
    "solana",
    "token-2022",
    "anchor",
    "security",
    "linter",
    "spl-token"
  ],
  "bin": {
    "token2022-guard": "./bin/token2022-guard.cjs"
  },
  "files": [
    "bin",
    "cli",
    "lib",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan": "tsx cli/index.ts",
    "scan:examples": "tsx cli/index.ts ./examples",
    "scan:sarif": "tsx cli/index.ts",
    "benchmark": "node scripts/benchmark.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "prepublishOnly": "npm run test && npm run smoke"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "@eslint/eslintrc": "^3",
    "vitest": "^3.0.5"
  }
}
